{
  "expo": {
    "name": "가포 알바",
    "slug": "alba-payroll-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "albapayroll",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1c2630"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.albapayroll.mobile",
      "buildNumber": "1",
      "entitlements": {
        "com.apple.developer.networking.wifi-info": true
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "근무지 주변에서 출퇴근을 자동 기록하기 위해 위치를 사용합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "백그라운드에서 출퇴근을 자동 기록하려면 위치 '항상 허용'이 필요합니다.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.albapayroll.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2b2b2b"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "근무지 주변에서 출퇴근을 자동 기록하기 위해 위치를 사용합니다.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c2b23f1f-8894-466d-844b-1636942f79ac"
      }
    },
    "owner": "innomvation"
  }
}
